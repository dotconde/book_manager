# Ignore bundled gems
/vendor/bundle

# Ignore the default SQLite database
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all environment files
/.env*

# Ignore all log files and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage files
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials and more
/config/master.key
/config/credentials/*.key

# Ignore precompiled assets
/public/assets

# Ignore node_modules
/node_modules

# macOS
.DS_Store
